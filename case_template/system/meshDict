FoamFile
{
    version   2.0;
    format    ascii;
    class     dictionary;
    location  "system";
    object    meshDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

surfaceFile "combined.fms";

maxCellSize 0.25;

localRefinement
{
    Wing
    {
        additionalRefinementLevels 9;
        refinementThickness 0.05;
    }
}

boundaryLayers
{
    patchBoundaryLayers
    {
        Wing
        {
            nLayers 10;
            thicknessRatio 1.2;
            maxFirstLayerThickness 0.000116;
            allowDiscontinuity 0; 
        }
    }
    optimiseLayer 1;
    optimisationParameters
    {
        nSmoothNormals 15;            // More smoothing iterations
        nSmoothSurfaceNormals 10;
        nSmoothThickness 10;
        reCalculateNormals 1;
        maxNumIterations 10;
    }
}

